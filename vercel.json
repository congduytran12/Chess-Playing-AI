{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "game/build/web",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/sync",
      "destination": "/api/sync.py"
    }
  ]
}

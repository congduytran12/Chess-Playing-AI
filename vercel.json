{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "game/build/web",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/sync",
      "destination": "/api/sync.py"
    },
    {
      "source": "/(browserfs.min.js|pythons.js|vtx.js|snd.js|gui.js|empty.html|.*\\.wasm|.*\\.data)",
      "destination": "https://pygame-web.github.io/cdn/0.9.3/$1"
    }
  ]
}

{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "game/build/web",
  "framework": null,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/pythons.js",
      "destination": "https://pygame-web.github.io/cdn/0.9.3/pythons.js"
    },
    {
      "source": "/browserfs.min.js",
      "destination": "https://pygame-web.github.io/cdn/0.9.3/browserfs.min.js"
    },
    {
      "source": "/api/sync",
      "destination": "/api/sync.py"
    }
  ]
}
